<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Giày Sneaker Store</title>
    <link rel="stylesheet" href="~/css/auth.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/style.css">
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-light sticky-top">
            <div class="container">
                <a class="navbar-brand fw-bold" href="/">
                    <i class="bi bi-lightning-charge-fill text-primary"></i> SNEAKERHUB
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item"><a class="nav-link active" href="/Product/Index">Trang chủ</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Product/Index">Sản phẩm</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Product/Create">Thêm sản phẩm</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Category/Index">Quản lý danh mục</a></li>
                    </ul>
                    <partial name = "_LoginPartial"></partial>
                </div>
            </div>
        </nav>
    </header>

    <div class="container my-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="bg-dark text-white py-4 mt-5">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h5><i class="bi bi-lightning-charge-fill"></i> SNEAKERHUB</h5>
                    <p class="small">Cửa hàng giày chính hãng, chất lượng cao.</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <p class="small mb-0">© 2024 SneakerHub. Tất cả quyền được bảo lưu.</p>
                    <p class="small mb-0">Liên hệ: info@sneakerhub.com | 0123 456 789</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>