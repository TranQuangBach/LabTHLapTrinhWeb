<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | SNEAKERHUB</title>

    <!-- CSS Dependencies -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />

    <!-- Custom Styles -->
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="d-flex flex-column min-h-screen">

    <!-- Header / Navbar -->
    <header class="sticky-top">
        <nav class="navbar navbar-expand-lg py-3">
            <div class="container max-w-7xl px-3 px-md-4">

                <!-- Logo -->
                <a class="navbar-brand fw-bold tracking-tight text-dark d-flex align-items-center gap-2" href="/">
                    <i class="bi bi-lightning-charge-fill text-dark fs-4"></i>
                    <span>SNEAKERHUB</span>
                </a>

                <!-- Mobile Toggle -->
                <button class="navbar-toggler border-0 px-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain" aria-controls="navbarMain" aria-expanded="false" aria-label="Mở menu">
                    <i class="bi bi-list fs-2 text-dark"></i>
                </button>

                <!-- Menu Links -->
                <div class="collapse navbar-collapse justify-content-center" id="navbarMain">
                    <ul class="navbar-nav gap-1 gap-lg-4 mb-3 mb-lg-0 mt-3 mt-lg-0 text-center">
                        <li class="nav-item">
                            <a class="nav-link text-uppercase tracking-wider" href="/">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-uppercase tracking-wider" href="/Product">Bộ sưu tập</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-uppercase tracking-wider" href="/Category/Details/1">Chạy bộ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-uppercase tracking-wider" href="/Category/Details/2">Lifestyle</a>
                        </li>
                    </ul>
                </div>

                <!-- User Actions (Login, Cart) -->
                <div class="collapse navbar-collapse flex-grow-0" id="navbarMain">
                    <partial name="_LoginPartial" />
                </div>

            </div>
        </nav>
    </header>

    <!-- Main Content Area -->
    <main role="main" class="flex-grow-1">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="site-footer pt-5 pb-4 mt-auto">
        <div class="container max-w-7xl px-3 px-md-4">
            <div class="row g-4 mb-5">
                <div class="col-12 col-md-4 pe-md-5">
                    <a class="d-flex align-items-center gap-2 text-dark text-decoration-none fw-bold tracking-tight mb-3" href="/">
                        <i class="bi bi-lightning-charge-fill fs-5"></i>
                        <span>SNEAKERHUB</span>
                    </a>
                    <p class="text-muted small lh-lg">
                        Không thỏa hiệp với thiết kế. Chúng tôi mang đến những mẫu giày thể thao kết hợp giữa hiệu năng và thẩm mỹ hiện đại.
                    </p>
                </div>
                <div class="col-6 col-md-2 offset-md-1">
                    <h5 class="footer-heading">Sản phẩm</h5>
                    <a href="#" class="footer-link">Giày chạy bộ</a>
                    <a href="#" class="footer-link">Giày tập luyện</a>
                    <a href="#" class="footer-link">Phiên bản giới hạn</a>
                    <a href="#" class="footer-link">Phụ kiện</a>
                </div>
                <div class="col-6 col-md-2">
                    <h5 class="footer-heading">Hỗ trợ</h5>
                    <a href="#" class="footer-link">Trung tâm trợ giúp</a>
                    <a href="#" class="footer-link">Tra cứu đơn hàng</a>
                    <a href="#" class="footer-link">Chính sách đổi trả</a>
                    <a href="#" class="footer-link">Bảo hành</a>
                </div>
                <div class="col-12 col-md-3">
                    <h5 class="footer-heading">Liên hệ</h5>
                    <a href="mailto:hello@sneakerhub.vn" class="footer-link"><i class="bi bi-envelope me-2"></i>hello@sneakerhub.vn</a>
                    <a href="tel:19001000" class="footer-link"><i class="bi bi-telephone me-2"></i>1900 1000</a>
                    <div class="d-flex gap-3 mt-4">
                        <a href="#" class="text-dark"><i class="bi bi-instagram fs-5"></i></a>
                        <a href="#" class="text-dark"><i class="bi bi-facebook fs-5"></i></a>
                        <a href="#" class="text-dark"><i class="bi bi-twitter-x fs-5"></i></a>
                    </div>
                </div>
            </div>

            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center pt-4 border-top">
                <p class="small text-muted mb-2 mb-md-0">&copy; @DateTime.Now.Year SneakerHub. Đã đăng ký bản quyền.</p>
                <div class="d-flex gap-3">
                    <a href="#" class="text-muted small text-decoration-none">Điều khoản</a>
                    <a href="#" class="text-muted small text-decoration-none">Bảo mật</a>
                </div>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>