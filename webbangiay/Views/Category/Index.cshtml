@model IEnumerable<Category>
@inject webbangiay.Repository.IProductRepository ProductRepository

@{
    ViewData["Title"] = "Quản lý danh mục";
    // Gọi hàm bất đồng bộ tương thích với IProductRepository mới
    var allProducts = await ProductRepository.GetAllAsync();
    var productList = allProducts ?? new List<Product>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Danh sách danh mục</h2>
    <a asp-action="CreateCategory" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Thêm danh mục mới
    </a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Tên danh mục</th>
                <th>Số lượng sản phẩm</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Name</td>
                        <td>
                            <span class="badge bg-info">
                                @productList.Count(p => p.CategoryId == item.Id)
                            </span>
                        </td>
                        <td>
                            <a asp-action="EditCategory" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                                <i class="bi bi-pencil"></i> Sửa
                            </a>
                            <a asp-action="DeleteCategory" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                                <i class="bi bi-trash"></i> Xóa
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center">Chưa có danh mục nào.</td>
                </tr>
            }
        </tbody>
    </table>
</div>