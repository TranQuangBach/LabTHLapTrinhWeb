@model IEnumerable<webbangiay.Models.Product>
@inject webbangiay.Repository.IProductRepository ProductRepo
@inject webbangiay.Repository.ICategoryRepository CategoryRepo

@{
    ViewData["Title"] = "Bộ sưu tập";
    var allCategories = await CategoryRepo.GetAllAsync();
}

<section class="py-5 max-w-7xl mx-auto px-3 px-md-4">
    <div class="text-center mb-5">
        <div class="d-flex justify-content-md-center gap-2 overflow-x-auto py-2 mb-5" style="scroll-snap-type: x mandatory; -ms-overflow-style: none; scrollbar-width: none;">
            <a asp-controller="Product" asp-action="Index"
               class="btn btn-dark rounded-pill px-4 py-2 fw-medium text-nowrap" style="scroll-snap-align: start;">
                Tất cả
            </a>

            @if (allCategories != null)
            {
                foreach (var cat in allCategories)
                {
                    <a asp-controller="Category" asp-action="Details" asp-route-id="@cat.Id"
                       class="btn btn-light border text-muted rounded-pill px-4 py-2 fw-medium text-nowrap transition-all"
                       style="scroll-snap-align: start;">
                        @cat.Name
                    </a>
                }
            }
        </div>

        <style>
            .overflow-x-auto::-webkit-scrollbar {
                display: none;
            }
        </style>

        <h1 class="display-5 fw-bold tracking-tight text-dark mb-3">Bộ sưu tập Mới</h1>
        <p class="lead text-muted mx-auto" style="max-width: 65ch;">
            Những thiết kế đột phá nhất dành cho chuyển động. Không thỏa hiệp về hiệu năng.
        </p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-0 mb-4" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
        </div>
    }

    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var item in Model)
        {
            // Logic truy vấn hình ảnh gốc của bạn
            var images = await ProductRepo.GetImagesByProductIdAsync(item.Id);
            var allImages = new List<string>();

            if (!string.IsNullOrEmpty(item.ImageUrl))
            {
                allImages.Add(item.ImageUrl);
            }

            if (images != null && images.Any())
            {
                foreach (var img in images)
                {
                    if (img.Url != item.ImageUrl)
                    {
                        allImages.Add(img.Url);
                    }
                }
            }

            if (!allImages.Any())
            {
                allImages.Add("https://via.placeholder.com/600x750?text=No+Image");
            }

            var carouselId = $"carousel-public-{item.Id}";
            var imageCount = allImages.Count;

            <div class="col">
                <div class="card border-0 h-100 bg-transparent group">
                    <!-- Carousel Hình ảnh -->
                    <div id="@carouselId" class="carousel slide position-relative overflow-hidden bg-light mb-3 rounded-3" data-bs-ride="false">
                        <div class="carousel-inner" style="aspect-ratio: 4/5;">
                            @for (int i = 0; i < allImages.Count; i++)
                            {
                                <div class="carousel-item @(i == 0 ? "active" : "") h-100">
                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="d-block h-100">
                                        <img src="@Url.Content(allImages[i])"
                                             class="d-block w-100 h-100 object-fit-cover transition-transform duration-500"
                                             alt="@item.Name"
                                             onmouseover="this.style.transform='scale(1.05)'"
                                             onmouseout="this.style.transform='scale(1)'"
                                             onerror="this.src='https://via.placeholder.com/600x750?text=No+Image'">
                                    </a>
                                </div>
                            }
                        </div>

                        @if (imageCount > 1)
                        {
                            <button class="carousel-control-prev" type="button" data-bs-target="#@carouselId" data-bs-slide="prev">
                                <span class="carousel-control-prev-icon bg-dark rounded-circle p-2 shadow-sm" aria-hidden="true"></span>
                                <span class="visually-hidden">Trước</span>
                            </button>
                            <button class="carousel-control-next" type="button" data-bs-target="#@carouselId" data-bs-slide="next">
                                <span class="carousel-control-next-icon bg-dark rounded-circle p-2 shadow-sm" aria-hidden="true"></span>
                                <span class="visually-hidden">Sau</span>
                            </button>

                            <div class="position-absolute top-0 end-0 m-2 z-1">
                                <span class="badge bg-dark bg-opacity-75 text-white fw-medium">
                                    <i class="bi bi-images me-1"></i> @imageCount
                                </span>
                            </div>
                        }
                    </div>

                    <!-- Thông tin sản phẩm -->
                    <div class="card-body p-0">
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <h3 class="fs-6 fw-bold text-dark mb-0">
                                <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none text-dark">
                                    @item.Name
                                </a>
                            </h3>
                            <span class="fw-bold text-dark fs-6 ms-2">@item.Price.ToString("#,0")₫</span>
                        </div>
                        <p class="text-muted small mb-2">@(item.Category?.Name ?? "Sneaker")</p>

                        <div class="d-flex align-items-center gap-2">
                            <div class="star-rating small">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= Math.Floor(item.Rating))
                                    {
                                        <i class="bi bi-star-fill text-dark"></i>
                                    }
                                    else if (i - item.Rating < 0.5)
                                    {

                                        <i class="bi bi-star-half text-dark"></i>
                                    }
                                    else
                                    {

                                        <i class="bi bi-star text-muted opacity-50"></i>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var carousels = document.querySelectorAll('.carousel');
            carousels.forEach(function(carousel) {
                new bootstrap.Carousel(carousel, {
                    interval: false,
                    wrap: true,
                    touch: true
                });
            });
        });
    </script>
}