@model webbangiay.Models.Product
@inject webbangiay.Repository.ICategoryRepository CategoryRepo

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
    var category = await CategoryRepo.GetByIdAsync(Model.CategoryId);
}

<div class="container my-4">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <div class="row">
                <div class="col-md-5 text-center mb-4 border rounded p-3 bg-light">
                    <img src="@Url.Content(Model.ImageUrl)" class="img-fluid rounded" alt="@Model.Name"
                         onerror="this.src='https://via.placeholder.com/500x400?text=No+Image'">
                </div>

                <div class="col-md-7 ps-md-4">
                    <span class="badge bg-info mb-2 fs-6">@(category?.Name ?? "Chưa phân loại")</span>
                    <h2 class="fw-bold mb-3">@Model.Name</h2>

                    <div class="mb-4">
                        <span class="fs-2 text-danger fw-bold">@Model.Price.ToString("#,0")₫</span>
                    </div>

                    <h5 class="fw-bold border-bottom pb-2">Mô tả sản phẩm</h5>
                    <p class="lead text-secondary fs-6" style="white-space: pre-line;">@Model.Description</p>

                    <div class="mt-5 pt-3 border-top d-flex gap-2">
                        <a asp-action="Index" class="btn btn-outline-secondary px-4"><i class="bi bi-arrow-left"></i> Quay lại</a>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning px-4 fw-bold"><i class="bi bi-pencil"></i> Sửa sản phẩm</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>