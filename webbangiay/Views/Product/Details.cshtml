@model webbangiay.Models.Product
@inject webbangiay.Repository.IProductRepository ProductRepo

@{
    ViewData["Title"] = Model.Name;

    // Logic truy vấn hình ảnh gốc
    var images = await ProductRepo.GetImagesByProductIdAsync(Model.Id);
    var allImages = new List<string>();

    if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        allImages.Add(Model.ImageUrl);
    }

    if (images != null && images.Any())
    {
        foreach (var img in images)
        {
            if (img.Url != Model.ImageUrl)
            {
                allImages.Add(img.Url);
            }
        }
    }

    if (!allImages.Any())
    {
        allImages.Add("https://via.placeholder.com/1000x1250?text=No+Image");
    }
}

<section class="py-5 px-3 px-md-4 max-w-7xl mx-auto">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb small fw-medium text-uppercase tracking-wider">
            <li class="breadcrumb-item"><a href="/" class="text-muted text-decoration-none hover-dark">Trang chủ</a></li>
            <li class="breadcrumb-item"><a href="/Product" class="text-muted text-decoration-none hover-dark">Cửa hàng</a></li>
            <li class="breadcrumb-item active text-dark" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="row g-5">
        <!-- Cột Trái: Gallery -->
        <div class="col-12 col-md-7">
            <div class="card border-0 rounded-4 overflow-hidden shadow-sm mb-3">
                <div id="productCarousel" class="carousel slide" data-bs-ride="false">
                    <div class="carousel-inner" style="aspect-ratio: 4/5;">
                        @for (int i = 0; i < allImages.Count; i++)
                        {
                            <div class="carousel-item @(i == 0 ? "active" : "") h-100">
                                <img src="@Url.Content(allImages[i])"
                                     class="d-block w-100 h-100 object-fit-cover"
                                     alt="Hình ảnh @Model.Name góc @(i + 1)"
                                     onerror="this.src='https://via.placeholder.com/1000x1250?text=No+Image'">
                            </div>
                        }
                    </div>

                    @if (allImages.Count > 1)
                    {
                        <button class="carousel-control-prev" type="button" data-bs-target="#productCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon bg-dark rounded-circle p-3 shadow-sm" aria-hidden="true"></span>
                            <span class="visually-hidden">Trước</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#productCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon bg-dark rounded-circle p-3 shadow-sm" aria-hidden="true"></span>
                            <span class="visually-hidden">Sau</span>
                        </button>
                    }
                </div>
            </div>

            <!-- Thumbnails -->
            @if (allImages.Count > 1)
            {
                <div class="row g-2">
                    @for (int i = 0; i < allImages.Count; i++)
                    {
                        <div class="col-2 col-sm-3">
                            <div class="rounded-3 overflow-hidden border border-light-subtle cursor-pointer"
                                 onclick="goToSlide(@i)"
                                 style="aspect-ratio: 1/1;">
                                <img src="@Url.Content(allImages[i])"
                                     class="w-100 h-100 object-fit-cover"
                                     alt="Thumbnail @(i + 1)"
                                     onerror="this.src='https://via.placeholder.com/200x200?text=No+Image'">
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Cột Phải: Thông tin & Giỏ hàng -->
        <div class="col-12 col-md-5">
            <div class="position-sticky" style="top: 2rem;">
                <span class="badge bg-light text-dark border mb-3 py-2 px-3 fw-medium">@(Model.Category?.Name ?? "Sneaker")</span>
                <h1 class="display-6 fw-bold tracking-tight text-dark mb-2">@Model.Name</h1>

                <div class="d-flex align-items-center gap-3 mb-4">
                    <p class="fs-3 fw-bold text-dark mb-0">@Model.Price.ToString("#,0")₫</p>
                    <div class="d-flex align-items-center text-dark">
                        <i class="bi bi-star-fill me-1 text-dark"></i>
                        <span class="fw-medium">@Model.Rating</span>
                    </div>
                </div>

                <div class="mb-5 text-muted lh-lg" style="white-space: pre-line;">
                    @Model.Description
                </div>

                <form action="/Cart/Add" method="post">
                    <input type="hidden" name="productId" value="@Model.Id" />

                    <button type="submit" class="btn btn-dark btn-lg w-100 rounded-pill py-3 fw-bold tracking-wider mb-3 transition-transform active-scale-down">
                        THÊM VÀO GIỎ HÀNG
                    </button>

                    <a asp-action="Index" class="btn btn-outline-dark btn-lg w-100 rounded-pill py-3 fw-medium">
                        Quay lại cửa hàng
                    </a>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        function goToSlide(index) {
            var carousel = document.getElementById('productCarousel');
            var bsCarousel = bootstrap.Carousel.getOrCreateInstance(carousel);
            bsCarousel.to(index);
        }
    </script>
}