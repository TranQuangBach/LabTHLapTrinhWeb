@page
@model LogoutModel

@{
    ViewData["Title"] = "Đăng xuất";
}

<div class="min-h-[100dvh] flex items-center justify-center bg-white dark:bg-zinc-950 px-4">
    <div class="text-center">
        <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center">
            <i class="bi bi-check-lg text-2xl text-green-600 dark:text-green-400"></i>
        </div>

        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <h1 class="text-2xl font-semibold tracking-tight text-zinc-900 dark:text-white mb-2">
                Đăng xuất?
            </h1>
            <p class="text-zinc-500 dark:text-zinc-400 mb-6">
                Bạn có chắc chắn muốn đăng xuất khỏi tài khoản?
            </p>
            <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                <button type="submit"
                        class="inline-flex items-center gap-2 bg-red-600 hover:bg-red-700 text-white px-6 py-2.5 rounded-xl font-medium active:scale-[0.98] transition-all">
                    <i class="bi bi-box-arrow-right"></i>
                    Đăng xuất
                </button>
                <a href="/"
                   class="inline-flex items-center gap-2 ml-3 text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white px-6 py-2.5 rounded-xl font-medium transition">
                    Hủy
                </a>
            </form>
        }
        else
        {
            <h1 class="text-2xl font-semibold tracking-tight text-zinc-900 dark:text-white mb-2">
                Đã đăng xuất
            </h1>
            <p class="text-zinc-500 dark:text-zinc-400 mb-6">
                Bạn đã đăng xuất thành công.
            </p>
            <a href="/"
               class="inline-flex items-center gap-2 bg-zinc-900 dark:bg-white text-white dark:text-zinc-900 px-6 py-2.5 rounded-xl font-medium hover:bg-zinc-800 dark:hover:bg-zinc-100 active:scale-[0.98] transition-all">
                <i class="bi bi-house"></i>
                Về trang chủ
            </a>
        }
    </div>
</div>