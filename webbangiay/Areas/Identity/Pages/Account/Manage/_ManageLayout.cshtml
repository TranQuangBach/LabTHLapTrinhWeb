@{
    Layout = "/Views/Shared/_Layout.cshtml";
}

<section class="py-5 px-3 px-md-4 max-w-7xl mx-auto min-h-screen">
    <!-- Tiêu đề trang -->
    <div class="mb-5 pb-3 border-bottom">
        <h1 class="display-6 fw-bold tracking-tight text-dark mb-1">Tài khoản của tôi</h1>
        <p class="text-muted mb-0">Quản lý hồ sơ, bảo mật và theo dõi đơn hàng.</p>
    </div>

    <div class="row g-5">
        <!-- Cột Menu Trái -->
        <div class="col-12 col-md-3">
            <partial name="_ManageNav" />
        </div>

        <!-- Cột Content Phải -->
        <div class="col-12 col-md-9">
            @RenderBody()
        </div>
    </div>
</section>

@section Scripts {
    @RenderSection("Scripts", required: false)
}