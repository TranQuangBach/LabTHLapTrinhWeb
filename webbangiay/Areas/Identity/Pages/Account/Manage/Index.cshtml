@page
@model webbangiay.Areas.Identity.Pages.Account.Manage.IndexModel
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}

<h3 class="fs-5 fw-bold text-dark mb-4">Thông tin cơ bản</h3>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-success alert-dismissible fade show rounded-0 mb-4" role="alert">
        @Model.StatusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
    </div>
}

<form id="profile-form" method="post" class="max-w-md">
    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

    <!-- Tên đăng nhập (Readonly) -->
    <div class="mb-4">
        <label asp-for="Username" class="form-label small fw-semibold text-uppercase tracking-wider">Tên đăng nhập (Email)</label>
        <input asp-for="Username" class="form-control bg-light border-light-subtle rounded-0 px-3 py-2 text-muted" disabled />
    </div>

    <!-- Số điện thoại (Editable) -->
    <div class="mb-4">
        <label asp-for="Input.PhoneNumber" class="form-label small fw-semibold text-uppercase tracking-wider">Số điện thoại</label>
        <input asp-for="Input.PhoneNumber" class="form-control border-dark rounded-0 px-3 py-2" placeholder="Nhập số điện thoại liên hệ" />
        <span asp-validation-for="Input.PhoneNumber" class="text-danger small mt-1 d-block"></span>
    </div>

    <button id="update-profile-button" type="submit" class="btn btn-dark rounded-0 px-5 py-3 fw-bold tracking-wider text-uppercase w-100">
        Lưu thay đổi
    </button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}