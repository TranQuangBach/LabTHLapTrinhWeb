@model webbangiay.Models.Product
@inject webbangiay.Repository.IProductRepository ProductRepo

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
    var images = await ProductRepo.GetImagesByProductIdAsync(Model.Id);
    var allImages = new List<string>();

    // Chỉ thêm ảnh đại diện nếu nó chưa có trong danh sách ảnh phụ
    if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        allImages.Add(Model.ImageUrl);
    }

    // Thêm ảnh phụ (KHÔNG thêm trùng với ảnh đại diện)
    if (images != null && images.Any())
    {
        foreach (var img in images)
        {
            if (img.Url != Model.ImageUrl) // Kiểm tra tránh trùng
            {
                allImages.Add(img.Url);
            }
        }
    }
}

<div class="container my-4">
    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div id="productCarousel" class="carousel slide" data-bs-ride="carousel">
                    <div class="carousel-inner">
                        @if (allImages.Any())
                        {
                            for (int i = 0; i < allImages.Count; i++)
                            {
                                <div class="carousel-item @(i == 0 ? "active" : "")">
                                    <img src="@Url.Content(allImages[i])"
                                         class="d-block w-100"
                                         style="height: 400px; object-fit: cover;"
                                         alt="Product image @(i + 1)"
                                         onerror="this.src='https://via.placeholder.com/600x400?text=No+Image'">
                                </div>
                            }
                        }
                        else
                        {
                            <div class="carousel-item active">
                                <img src="https://via.placeholder.com/600x400?text=No+Image"
                                     class="d-block w-100" style="height: 400px; object-fit: cover;">
                            </div>
                        }
                    </div>

                    @if (allImages.Count > 1)
                    {
                        <button class="carousel-control-prev" type="button" data-bs-target="#productCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon bg-dark rounded-circle p-3" aria-hidden="true"></span>
                            <span class="visually-hidden">Previous</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#productCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon bg-dark rounded-circle p-3" aria-hidden="true"></span>
                            <span class="visually-hidden">Next</span>
                        </button>
                    }
                </div>
            </div>

            @* Hiển thị thumbnail bên dưới - CĂN ĐỀU *@
            @if (allImages.Count > 1)
            {
                <div class="row mt-3 g-2">
                    @for (int i = 0; i < allImages.Count; i++)
                    {
                        <div class="col-3">
                            <img src="@Url.Content(allImages[i])"
                                 class="img-thumbnail w-100"
                                 style="height: 80px; object-fit: cover; cursor: pointer;"
                                 onclick="goToSlide(@i)"
                                 onerror="this.src='https://via.placeholder.com/100x80?text=No+Image'">
                        </div>
                    }
                </div>
            }
        </div>

        <div class="col-md-6">
            <span class="badge bg-info mb-2 fs-6">@(Model.Category?.Name ?? "Chưa phân loại")</span>
            <h2 class="fw-bold mb-3">@Model.Name</h2>

            <div class="mb-4">
                <span class="fs-2 text-danger fw-bold">@Model.Price.ToString("#,0")₫</span>
            </div>

            <div class="star-rating mb-3">
                @for (int i = 1; i <= 5; i++)
                {
                    if (i <= Math.Floor(Model.Rating))
                    {
                        <i class="bi bi-star-fill text-warning"></i>
                    }
                    else if (i - Model.Rating < 0.5)
                    {
                        <i class="bi bi-star-half text-warning"></i>
                    }
                    else
                    {
                        <i class="bi bi-star text-warning"></i>
                    }
                }
                <span class="text-muted ms-2">(@Model.Rating sao)</span>
            </div>

            <h5 class="fw-bold border-bottom pb-2">Mô tả sản phẩm</h5>
            <p class="text-secondary fs-6" style="white-space: pre-line;">@Model.Description</p>

            <div class="mt-5 pt-3 border-top d-flex gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary px-4">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning px-4 fw-bold">
                    <i class="bi bi-pencil"></i> Sửa sản phẩm
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function goToSlide(index) {
            var carousel = document.getElementById('productCarousel');
            var bsCarousel = bootstrap.Carousel.getOrCreateInstance(carousel);
            bsCarousel.to(index);
        }
    </script>
}