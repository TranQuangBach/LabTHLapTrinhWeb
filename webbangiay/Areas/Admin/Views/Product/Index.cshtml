@model IEnumerable<webbangiay.Models.Product>
@inject webbangiay.Repository.IProductRepository ProductRepo

@{
    ViewData["Title"] = "Quản lý Sản phẩm";
}

<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <h2 class="h4 mb-1 fw-bold text-dark">Danh mục sản phẩm</h2>
        <p class="text-muted small mb-0">Quản lý kho hàng và thông tin hiển thị.</p>
    </div>
    <a asp-action="Create" class="btn btn-dark px-4 py-2 fw-medium rounded-3">
        <i class="bi bi-plus-lg me-2"></i>Thêm sản phẩm mới
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
    </div>
}

<div class="table-responsive rounded-3 border bg-white shadow-sm">
    <table class="table table-hover table-borderless align-middle mb-0">
        <thead class="table-light border-bottom text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.5px;">
            <tr>
                <th scope="col" class="py-3 ps-4" style="width: 140px;">Hình ảnh</th>
                <th scope="col" class="py-3">Tên sản phẩm</th>
                <th scope="col" class="py-3">Danh mục</th>
                <th scope="col" class="py-3 text-end">Giá bán</th>
                <th scope="col" class="py-3 text-center" style="width: 160px;">Thao tác</th>
            </tr>
        </thead>
        <tbody class="border-top-0">
            @foreach (var item in Model)
            {
                var images = await ProductRepo.GetImagesByProductIdAsync(item.Id);
                var allImages = new List<string>();

                if (!string.IsNullOrEmpty(item.ImageUrl)) { allImages.Add(item.ImageUrl); }
                if (images != null && images.Any())
                {
                    foreach (var img in images)
                    {
                        if (img.Url != item.ImageUrl) { allImages.Add(img.Url); }
                    }
                }
                if (!allImages.Any()) { allImages.Add("https://via.placeholder.com/100x100?text=No+Image"); }

                var carouselId = $"carousel-admin-{item.Id}";

                <tr class="border-bottom">
                    <td class="ps-4">
                        <!-- Mini Carousel cho Table Admin -->
                        <div id="@carouselId" class="carousel slide rounded overflow-hidden border" data-bs-ride="false" style="width: 80px; height: 80px;">
                            <div class="carousel-inner h-100">
                                @for (int i = 0; i < allImages.Count; i++)
                                {
                                    <div class="carousel-item @(i == 0 ? "active" : "") h-100">
                                        <img src="@Url.Content(allImages[i])" class="d-block w-100 h-100 object-fit-cover" alt="Image @i">
                                    </div>
                                }
                            </div>
                            @if (allImages.Count > 1)
                            {
                                <button class="carousel-control-prev" type="button" data-bs-target="#@carouselId" data-bs-slide="prev">
                                    <span class="carousel-control-prev-icon" aria-hidden="true" style="width: 1rem; height: 1rem;"></span>
                                </button>
                                <button class="carousel-control-next" type="button" data-bs-target="#@carouselId" data-bs-slide="next">
                                    <span class="carousel-control-next-icon" aria-hidden="true" style="width: 1rem; height: 1rem;"></span>
                                </button>
                            }
                        </div>
                    </td>
                    <td>
                        <div class="fw-semibold text-dark">@item.Name</div>
                        <div class="text-muted small text-truncate" style="max-width: 250px;">
                            <i class="bi bi-star-fill text-warning me-1"></i>@item.Rating | @item.Description
                        </div>
                    </td>
                    <td>
                        <span class="badge bg-light text-dark border">@(item.Category?.Name ?? "Chưa phân loại")</span>
                    </td>
                    <td class="text-end fw-medium text-dark">
                        @item.Price.ToString("#,0") ₫
                    </td>
                    <td class="text-center">
                        <div class="btn-group shadow-sm">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" title="Sửa"><i class="bi bi-pencil"></i></a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" title="Chi tiết"><i class="bi bi-eye"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Xóa"><i class="bi bi-trash"></i></a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var carousels = document.querySelectorAll('.carousel');
            carousels.forEach(function(carousel) {
                new bootstrap.Carousel(carousel, { interval: false, wrap: true });
            });
        });
    </script>
}