@model IEnumerable<webbangiay.Models.Product>
@inject webbangiay.Repository.IProductRepository ProductRepo

@{
    ViewData["Title"] = "Quản lý sản phẩm";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Danh sách sản phẩm</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Thêm sản phẩm mới
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    @foreach (var item in Model)
    {
        var images = await ProductRepo.GetImagesByProductIdAsync(item.Id);
        var allImages = new List<string>();

        if (!string.IsNullOrEmpty(item.ImageUrl))
        {
            allImages.Add(item.ImageUrl);
        }

        if (images != null && images.Any())
        {
            foreach (var img in images)
            {
                if (img.Url != item.ImageUrl)
                {
                    allImages.Add(img.Url);
                }
            }
        }

        if (!allImages.Any())
        {
            allImages.Add("https://via.placeholder.com/300x250?text=No+Image");
        }

        var carouselId = $"carousel{item.Id}";
        var imageCount = allImages.Count;

        <div class="col-md-4 col-lg-4">
            <div class="card h-100 shadow-sm">
                <!-- Carousel -->
                <div id="@carouselId" class="carousel slide" data-bs-ride="carousel" data-bs-interval="false">
                    <div class="carousel-inner">
                        @for (int i = 0; i < allImages.Count; i++)
                        {
                            <div class="carousel-item @(i == 0 ? "active" : "")">
                                <img src="@Url.Content(allImages[i])"
                                     class="d-block w-100"
                                     alt="@item.Name"
                                     style="height: 220px; object-fit: cover;"
                                     onerror="this.src='https://via.placeholder.com/300x220?text=No+Image'">
                            </div>
                        }
                    </div>

                    @if (imageCount > 1)
                    {
                        <button class="carousel-control-prev" type="button" data-bs-target="#@carouselId" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon bg-dark rounded-circle p-2" aria-hidden="true"></span>
                            <span class="visually-hidden">Previous</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#@carouselId" data-bs-slide="next">
                            <span class="carousel-control-next-icon bg-dark rounded-circle p-2" aria-hidden="true"></span>
                            <span class="visually-hidden">Next</span>
                        </button>
                    }
                </div>

                @if (imageCount > 1)
                {
                    <div class="position-absolute top-0 end-0 m-2">
                        <span class="badge bg-dark opacity-75">
                            <i class="bi bi-images"></i> @imageCount
                        </span>
                    </div>
                }

                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <h5 class="card-title fw-bold text-dark">@item.Name</h5>
                        <p class="card-text text-muted small text-truncate">@item.Description</p>
                        <span class="badge bg-info mb-2">@(item.Category?.Name ?? "Không rõ danh mục")</span>

                        <div class="star-rating mb-2">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= Math.Floor(item.Rating))
                                {
                                    <i class="bi bi-star-fill text-warning"></i>
                                }
                                else if (i - item.Rating < 0.5)
                                {
                                    <i class="bi bi-star-half text-warning"></i>
                                }
                                else
                                {
                                    <i class="bi bi-star text-warning"></i>
                                }
                            }
                            <span class="text-muted small">(@item.Rating)</span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-3 pt-2 border-top">
                        <span class="text-danger fw-bold fs-5">@item.Price.ToString("#,0")₫</span>
                        <div class="btn-group">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Khởi tạo carousel khi DOM đã sẵn sàng
        document.addEventListener('DOMContentLoaded', function() {
            var carousels = document.querySelectorAll('.carousel');
            carousels.forEach(function(carousel) {
                new bootstrap.Carousel(carousel, {
                    interval: false,
                    wrap: true,
                    touch: true
                });
            });
        });
    </script>
}