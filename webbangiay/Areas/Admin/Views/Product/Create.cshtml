@model webbangiay.Models.Product
@{
    ViewData["Title"] = "Thêm Sản phẩm";
}

<div class="mb-4">
    <h2 class="h4 mb-1 fw-bold text-dark">Thêm sản phẩm mới</h2>
    <p class="text-muted small">Điền thông tin chi tiết cho sản phẩm mới.</p>
</div>

<form asp-action="Create" enctype="multipart/form-data">
    <div class="row g-4">
        <div class="col-12 col-lg-8">
            <div class="card border border-light-subtle shadow-sm">
                <div class="card-body p-4">
                    <h5 class="card-title fs-6 fw-bold mb-4">Thông tin cơ bản</h5>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label small fw-medium">Tên sản phẩm</label>
                        <input asp-for="Name" class="form-control" placeholder="Ví dụ: Giày Chạy Bộ Nam Pro" required />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label small fw-medium">Mô tả chi tiết</label>
                        <textarea asp-for="Description" class="form-control" rows="5" placeholder="Nhập mô tả sản phẩm..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-4">
            <div class="card border border-light-subtle shadow-sm mb-4">
                <div class="card-body p-4">
                    <h5 class="card-title fs-6 fw-bold mb-4">Tổ chức</h5>

                    <div class="mb-3">
                        <label asp-for="Price" class="form-label small fw-medium">Giá bán (VNĐ)</label>
                        <div class="input-group">
                            <input asp-for="Price" type="number" class="form-control" min="0" required />
                            <span class="input-group-text">₫</span>
                        </div>
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CategoryId" class="form-label small fw-medium">Danh mục</label>
                        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId" required>
                            <option value="">Chọn danh mục</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-dark py-2 fw-medium">Lưu sản phẩm</button>
                <a asp-action="Index" class="btn btn-light border py-2 fw-medium text-dark">Hủy bỏ</a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}