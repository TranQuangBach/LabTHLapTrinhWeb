@model Category

@{
    ViewData["Title"] = "Xóa danh mục";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 border-top border-danger border-4">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">@ViewData["Title"]</h4>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-warning mb-4">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        Bạn có chắc chắn muốn xóa danh mục này? Hành động này sẽ gỡ hoàn toàn danh mục khỏi hệ thống.
                    </div>

                    <dl class="row bg-light p-3 rounded mb-4">
                        <dt class="col-sm-4 text-muted">ID danh mục</dt>
                        <dd class="col-sm-8 fw-bold">#@Model.Id</dd>

                        <dt class="col-sm-4 text-muted">Tên danh mục</dt>
                        <dd class="col-sm-8 fw-bold text-danger">@Model.Name</dd>
                    </dl>

                    <form asp-action="DeleteConfirmed" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">Hủy bỏ</a>
                            <button type="submit" class="btn btn-danger px-4 fw-bold">Xác nhận xóa</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>